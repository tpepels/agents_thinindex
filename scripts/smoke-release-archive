#!/usr/bin/env sh
set -eu

ARCHIVE="${1:-}"

if [ -z "$ARCHIVE" ]; then
    echo "usage: scripts/smoke-release-archive <archive>" >&2
    exit 2
fi

if [ ! -f "$ARCHIVE" ]; then
    echo "error: archive not found: $ARCHIVE" >&2
    exit 1
fi

CHECKSUM_PATH="$ARCHIVE.sha256"
if [ ! -f "$CHECKSUM_PATH" ]; then
    echo "error: checksum sidecar not found: $CHECKSUM_PATH" >&2
    exit 1
fi

case "$ARCHIVE" in
    */*)
        ARCHIVE_DIR="${ARCHIVE%/*}"
        ARCHIVE_BASE="${ARCHIVE##*/}"
        ;;
    *)
        ARCHIVE_DIR="."
        ARCHIVE_BASE="$ARCHIVE"
        ;;
esac

CHECKSUM_BASE="$ARCHIVE_BASE.sha256"
if command -v sha256sum >/dev/null 2>&1; then
    (cd "$ARCHIVE_DIR" && sha256sum -c "$CHECKSUM_BASE")
elif command -v shasum >/dev/null 2>&1; then
    (cd "$ARCHIVE_DIR" && shasum -a 256 -c "$CHECKSUM_BASE")
else
    echo "error: sha256sum or shasum is required to verify checksums" >&2
    exit 1
fi

WORK_DIR="$(mktemp -d "${TMPDIR:-/tmp}/thinindex-release-smoke.XXXXXX")"
cleanup() {
    rm -rf "$WORK_DIR"
}
trap cleanup EXIT INT TERM

case "$ARCHIVE" in
    *.tar.gz)
        PACKAGE_ROOT="$(tar -tzf "$ARCHIVE" | sed -n '1s#/.*##p')"
        tar -xzf "$ARCHIVE" -C "$WORK_DIR"
        ;;
    *.zip)
        if command -v zipinfo >/dev/null 2>&1; then
            PACKAGE_ROOT="$(zipinfo -1 "$ARCHIVE" | sed -n '1s#/.*##p')"
        elif command -v unzip >/dev/null 2>&1; then
            PACKAGE_ROOT="$(unzip -Z1 "$ARCHIVE" | sed -n '1s#/.*##p')"
        else
            echo "error: zipinfo or unzip is required to inspect zip archives" >&2
            exit 1
        fi
        if ! command -v unzip >/dev/null 2>&1; then
            echo "error: unzip is required to smoke-test zip archives" >&2
            exit 1
        fi
        unzip -q "$ARCHIVE" -d "$WORK_DIR"
        ;;
    *)
        echo "error: unsupported archive extension: $ARCHIVE" >&2
        exit 1
        ;;
esac

if [ -z "$PACKAGE_ROOT" ]; then
    echo "error: failed to determine archive root directory" >&2
    exit 1
fi

PACKAGE_DIR="$WORK_DIR/$PACKAGE_ROOT"
if [ ! -d "$PACKAGE_DIR" ]; then
    echo "error: extracted package root not found: $PACKAGE_ROOT" >&2
    exit 1
fi

EXE_SUFFIX=""
if [ -f "$PACKAGE_DIR/wi.exe" ]; then
    EXE_SUFFIX=".exe"
fi

require_packaged_binary() {
    binary="$1"
    path="$PACKAGE_DIR/$binary$EXE_SUFFIX"
    if [ ! -f "$path" ]; then
        echo "error: packaged binary missing: $binary$EXE_SUFFIX" >&2
        exit 1
    fi
    if [ ! -x "$path" ]; then
        echo "error: packaged binary is not executable: $binary$EXE_SUFFIX" >&2
        exit 1
    fi
}

require_packaged_binary wi
require_packaged_binary build_index
require_packaged_binary wi-init
require_packaged_binary wi-stats

"$PACKAGE_DIR/wi$EXE_SUFFIX" --help >/dev/null

SMOKE_REPO="$WORK_DIR/repo"
mkdir -p "$SMOKE_REPO"
cat > "$SMOKE_REPO/smoke.rs" <<'SMOKE'
pub fn thinindex_release_smoke_symbol() {}
SMOKE

(
    cd "$SMOKE_REPO"
    "$PACKAGE_DIR/wi-init$EXE_SUFFIX" >/dev/null
    "$PACKAGE_DIR/build_index$EXE_SUFFIX" >/dev/null
    DOCTOR_OUTPUT="$("$PACKAGE_DIR/wi$EXE_SUFFIX" doctor)"
    printf '%s\n' "$DOCTOR_OUTPUT"
    if printf '%s\n' "$DOCTOR_OUTPUT" | grep -q '^\[fail\]'; then
        echo "error: packaged wi doctor reported a failure" >&2
        exit 1
    fi
)

echo "release archive smoke ok: $ARCHIVE"
