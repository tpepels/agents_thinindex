#!/usr/bin/env sh
set -eu

BINARIES="wi build_index wi-init wi-stats"
SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
ARCHIVE_ROOT="${ARCHIVE_ROOT:-$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)}"
PREFIX="${PREFIX:-$HOME/.local}"
BIN_DIR="${BIN_DIR:-$PREFIX/bin}"
NOTICE_PATH="$ARCHIVE_ROOT/THIRD_PARTY_NOTICES"

if [ ! -f "$NOTICE_PATH" ]; then
    echo "error: missing archive notice file: $NOTICE_PATH" >&2
    exit 1
fi

mkdir -p "$BIN_DIR"

for binary in $BINARIES; do
    source_path="$ARCHIVE_ROOT/$binary"
    if [ ! -f "$source_path" ]; then
        echo "error: missing archive binary: $source_path" >&2
        exit 1
    fi
    install -m 0755 "$source_path" "$BIN_DIR/$binary"
done

for binary in $BINARIES; do
    if [ ! -x "$BIN_DIR/$binary" ]; then
        echo "error: install failed: $BIN_DIR/$binary is not executable" >&2
        exit 1
    fi
done

for binary in $BINARIES; do
    version_output="$("$BIN_DIR/$binary" --version)"
    echo "$version_output"
    case "$version_output" in
        *"index schema"*) ;;
        *)
            echo "error: installed $BIN_DIR/$binary did not report its index schema" >&2
            exit 1
            ;;
    esac
done

expected_schema="$("$BIN_DIR/build_index" --version | sed -n 's/.*index schema \([0-9][0-9]*\).*/\1/p')"
if [ -z "$expected_schema" ]; then
    echo "error: installed build_index did not report a parseable index schema" >&2
    exit 1
fi

for binary in $BINARIES; do
    version_output="$("$BIN_DIR/$binary" --version)"
    case "$version_output" in
        *"index schema $expected_schema"*) ;;
        *)
            echo "error: installed $BIN_DIR/$binary did not report expected index schema $expected_schema" >&2
            exit 1
            ;;
    esac
done

for binary in $BINARIES; do
    active_path="$(command -v "$binary" 2>/dev/null || true)"
    if [ -n "$active_path" ] && [ "$active_path" != "$BIN_DIR/$binary" ]; then
        echo "warning: PATH resolves $binary to $active_path, not $BIN_DIR/$binary"
    fi
done

case ":$PATH:" in
    *":$BIN_DIR:"*) ;;
    *)
        echo "warning: $BIN_DIR is not on PATH"
        echo "add this to your shell config:"
        echo "  export PATH=\"$BIN_DIR:\$PATH\""
        ;;
esac

echo "installed:"
for binary in $BINARIES; do
    echo "  $BIN_DIR/$binary"
done

cat <<'NOTE'

Note:
  This installer copies thinindex commands only.
  It does not run wi-init, create .dev_index, or mutate user repositories.
  Keep THIRD_PARTY_NOTICES with distributed release artifacts.
NOTE
