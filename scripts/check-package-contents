#!/usr/bin/env sh
set -eu

ARCHIVE="${1:-}"

if [ -z "$ARCHIVE" ]; then
    echo "usage: scripts/check-package-contents <archive>" >&2
    exit 2
fi

if [ ! -f "$ARCHIVE" ]; then
    echo "error: archive not found: $ARCHIVE" >&2
    exit 1
fi

case "$ARCHIVE" in
    */*) ARCHIVE_BASE="${ARCHIVE##*/}" ;;
    *) ARCHIVE_BASE="$ARCHIVE" ;;
esac

case "$ARCHIVE_BASE" in
    thinindex-*-*.tar.gz|thinindex-*-*.zip) ;;
    *)
        echo "error: archive name must start with thinindex- and include version/target: $ARCHIVE" >&2
        exit 1
        ;;
esac

case "$ARCHIVE_BASE" in
    *.tar.gz) PACKAGE_NAME="${ARCHIVE_BASE%.tar.gz}" ;;
    *.zip) PACKAGE_NAME="${ARCHIVE_BASE%.zip}" ;;
esac

case "$ARCHIVE_BASE" in
    *windows*|*msvc*|*mingw*) EXE_SUFFIX=".exe" ;;
    *) EXE_SUFFIX="" ;;
esac

case "$ARCHIVE" in
    *.tar.gz)
        CONTENTS="$(tar -tzf "$ARCHIVE")"
        ;;
    *.zip)
        if command -v zipinfo >/dev/null 2>&1; then
            CONTENTS="$(zipinfo -1 "$ARCHIVE")"
        elif command -v unzip >/dev/null 2>&1; then
            CONTENTS="$(unzip -Z1 "$ARCHIVE")"
        else
            echo "error: zipinfo or unzip is required to inspect zip archives" >&2
            exit 1
        fi
        ;;
    *)
        echo "error: unsupported archive extension: $ARCHIVE" >&2
        exit 1
        ;;
esac

require_entry() {
    pattern="$1"
    label="$2"
    if ! printf '%s\n' "$CONTENTS" | grep -Eq "$pattern"; then
        echo "error: archive missing $label" >&2
        exit 1
    fi
}

first_entry() {
    pattern="$1"
    label="$2"
    entry="$(printf '%s\n' "$CONTENTS" | grep -E "$pattern" | head -n 1 || true)"
    if [ -z "$entry" ]; then
        echo "error: archive missing $label" >&2
        exit 1
    fi
    printf '%s\n' "$entry"
}

reject_entry() {
    pattern="$1"
    label="$2"
    if printf '%s\n' "$CONTENTS" | grep -Eiq "$pattern"; then
        echo "error: archive contains forbidden $label" >&2
        exit 1
    fi
}

is_allowed_entry() {
    case "$1" in
        "$PACKAGE_NAME"|"$PACKAGE_NAME/") return 0 ;;
        "$PACKAGE_NAME/wi$EXE_SUFFIX") return 0 ;;
        "$PACKAGE_NAME/build_index$EXE_SUFFIX") return 0 ;;
        "$PACKAGE_NAME/wi-init$EXE_SUFFIX") return 0 ;;
        "$PACKAGE_NAME/wi-stats$EXE_SUFFIX") return 0 ;;
        "$PACKAGE_NAME/README.md") return 0 ;;
        "$PACKAGE_NAME/INSTALL.md") return 0 ;;
        "$PACKAGE_NAME/SBOM.md") return 0 ;;
        "$PACKAGE_NAME/THIRD_PARTY_NOTICES") return 0 ;;
        "$PACKAGE_NAME/LICENSE") return 0 ;;
        "$PACKAGE_NAME/docs"|"$PACKAGE_NAME/docs/") return 0 ;;
        "$PACKAGE_NAME/docs/CI_INTEGRATION.md") return 0 ;;
        "$PACKAGE_NAME/docs/GETTING_STARTED.md") return 0 ;;
        "$PACKAGE_NAME/docs/RELEASING.md") return 0 ;;
        "$PACKAGE_NAME/docs/INSTALLERS.md") return 0 ;;
        "$PACKAGE_NAME/docs/LICENSING.md") return 0 ;;
        "$PACKAGE_NAME/docs/SECURITY_PRIVACY.md") return 0 ;;
        "$PACKAGE_NAME/docs/TEAM_CI_ROADMAP.md") return 0 ;;
        "$PACKAGE_NAME/docs/TROUBLESHOOTING.md") return 0 ;;
        "$PACKAGE_NAME/scripts"|"$PACKAGE_NAME/scripts/") return 0 ;;
        "$PACKAGE_NAME/scripts/install-archive-unix") return 0 ;;
        "$PACKAGE_NAME/scripts/uninstall-archive-unix") return 0 ;;
        "$PACKAGE_NAME/scripts/windows"|"$PACKAGE_NAME/scripts/windows/") return 0 ;;
        "$PACKAGE_NAME/scripts/windows/install.ps1") return 0 ;;
        "$PACKAGE_NAME/scripts/windows/uninstall.ps1") return 0 ;;
        *) return 1 ;;
    esac
}

archive_text_entry() {
    entry="$1"
    case "$ARCHIVE" in
        *.tar.gz)
            tar -xOzf "$ARCHIVE" "$entry"
            ;;
        *.zip)
            if ! command -v unzip >/dev/null 2>&1; then
                echo "error: unzip is required to inspect zip archive file contents" >&2
                exit 1
            fi
            unzip -p "$ARCHIVE" "$entry"
            ;;
    esac
}

require_sbom_text() {
    needle="$1"
    label="$2"
    if ! printf '%s\n' "$SBOM_CONTENT" | grep -Fq -- "$needle"; then
        echo "error: SBOM.md missing $label: $needle" >&2
        exit 1
    fi
}

require_entry '/wi(\.exe)?$' "wi binary"
require_entry '/build_index(\.exe)?$' "build_index binary"
require_entry '/wi-init(\.exe)?$' "wi-init binary"
require_entry '/wi-stats(\.exe)?$' "wi-stats binary"
require_entry '/THIRD_PARTY_NOTICES$' "THIRD_PARTY_NOTICES"
require_entry '/README\.md$' "README.md"
require_entry '/INSTALL\.md$' "INSTALL.md"
require_entry '/SBOM\.md$' "SBOM.md"
require_entry '/docs/CI_INTEGRATION\.md$' "docs/CI_INTEGRATION.md"
require_entry '/docs/GETTING_STARTED\.md$' "docs/GETTING_STARTED.md"
require_entry '/docs/RELEASING\.md$' "docs/RELEASING.md"
require_entry '/docs/INSTALLERS\.md$' "docs/INSTALLERS.md"
require_entry '/docs/LICENSING\.md$' "docs/LICENSING.md"
require_entry '/docs/SECURITY_PRIVACY\.md$' "docs/SECURITY_PRIVACY.md"
require_entry '/docs/TEAM_CI_ROADMAP\.md$' "docs/TEAM_CI_ROADMAP.md"
require_entry '/docs/TROUBLESHOOTING\.md$' "docs/TROUBLESHOOTING.md"

for entry in $CONTENTS; do
    if ! is_allowed_entry "$entry"; then
        echo "error: archive contains unexpected entry: $entry" >&2
        exit 1
    fi
done

FORBIDDEN_EXTERNAL_TOOL="c""tags"
reject_entry '(^|/)\.dev_index(/|$)' ".dev_index"
reject_entry '(^|/)test_repos(/|$)' "test_repos"
reject_entry '(^|/)target(/|$)' "target build directory"
reject_entry '(^|/)dist(/|$)' "dist build directory"
reject_entry '(^|/)QUALITY_REPORT(\.md|\.json|_DETAILS\.jsonl)?$' "local quality report"
reject_entry '(^|/)COMPARATOR_TRIAGE\.md$' "local comparator triage report"
reject_entry "(^|/)($FORBIDDEN_EXTERNAL_TOOL|$FORBIDDEN_EXTERNAL_TOOL\\.exe|$FORBIDDEN_EXTERNAL_TOOL-[^/]*)$" "forbidden external comparator binary"
reject_entry '(^|/)(id_rsa|id_dsa|id_ecdsa|id_ed25519|[^/]+\.(p12|pfx|pem|key|mobileprovision))$' "signing secret or certificate-like material"

CHECKSUM_PATH="$ARCHIVE.sha256"
if [ -f "$CHECKSUM_PATH" ] && ! grep -Fq "$ARCHIVE_BASE" "$CHECKSUM_PATH"; then
    echo "error: checksum sidecar does not reference archive basename: $CHECKSUM_PATH" >&2
    exit 1
fi

SBOM_ENTRY="$(first_entry '/SBOM\.md$' "SBOM.md")"
SBOM_CONTENT="$(archive_text_entry "$SBOM_ENTRY")"

require_sbom_text "# thinindex release SBOM" "title"
require_sbom_text "\`scripts/package-release\`" "generator"
require_sbom_text "- package: thinindex" "package name"
require_sbom_text "- archive: $ARCHIVE_BASE" "archive basename"
require_sbom_text "- checksum: $ARCHIVE_BASE.sha256" "checksum sidecar"
require_sbom_text "- package manager: Cargo" "package manager"
require_sbom_text "- license audit: \`cargo deny check licenses\`" "license audit command"
require_sbom_text "## Shipped binaries" "shipped binaries section"
require_sbom_text "- wi$EXE_SUFFIX" "wi binary"
require_sbom_text "- build_index$EXE_SUFFIX" "build_index binary"
require_sbom_text "- wi-init$EXE_SUFFIX" "wi-init binary"
require_sbom_text "- wi-stats$EXE_SUFFIX" "wi-stats binary"
require_sbom_text "## Bundled notices" "bundled notices section"
require_sbom_text "\`THIRD_PARTY_NOTICES\`" "third-party notices"
require_sbom_text "## Not bundled" "not bundled section"
require_sbom_text "optional external comparator binaries" "external comparator exclusion"
require_sbom_text "signing keys, certificates" "signing secret exclusion"
require_sbom_text "repo-local indexes, quality reports, test repositories, build output, dist" "local artifact exclusions"

echo "package content ok: $ARCHIVE"
